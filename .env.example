# Configuración del Servidor de Base de Datos y Aplicación
PORT=8000
APP_URL=http://localhost:8000
DB_PATH=data/asistencias.sqlite

# Configuración del Dispositivo Biométrico Hikvision (Credenciales cifradas con CRYPTO_KEY)
BIOMETRIC_URL=http://<IP_PUBLICA_BIOMETRICO>:<PUERTO>/ISAPI/AccessControl/AcsEvent?format=json
BIOMETRIC_USER=<USUARIO_CIFRADO_O_TEXTO_PLANO>
BIOMETRIC_PASS=<PASSWORD_CIFRADO_O_TEXTO_PLANO>

# Habilitar simulación (true para marcas de prueba locales, false para conectar al biométrico físico real)
BIOMETRIC_SIMULATE=true

# Configuración de Seguridad y Autenticación del Panel de Asistencia
ADMIN_USER=admin
ADMIN_PASS= # Hash bcrypt del password del admin (puedes generarlo usando password_hash en PHP)
JWT_SECRET= # Clave secreta larga para firmar los tokens JWT del panel
CRYPTO_KEY= # Clave secreta para encriptar/desencriptar las credenciales del biométrico
